<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        (function () {
            document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark');
        })();
    </script>
    <title>Admin - @ViewData["Title"] | Linear AI</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/panel.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body class="panel-body admin-panel">
    <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
        <span data-theme-icon>🌙</span>
    </button>

    <div id="globalSkeleton" class="global-skeleton" aria-hidden="true">
        <div class="skeleton-line w-40"></div>
        <div class="skeleton-line w-80"></div>
        <div class="skeleton-line w-100"></div>
        <div class="skeleton-line w-60"></div>
    </div>

    <nav class="sidebar admin-sidebar">
        <div class="sidebar-brand">⚡ Admin</div>
        <ul class="nav-links">
            <li><a asp-controller="Admin" asp-action="Index">👤 Account</a></li>
            <li><a asp-controller="Admin" asp-action="Orders">🛒 Orders</a></li>
            <li><a asp-controller="Admin" asp-action="Products">📦 Products</a></li>
            <li><a asp-controller="Admin" asp-action="Vouchers">🎟️ Vouchers</a></li>
            <ul class="nav-links">
                
            </ul>
        </ul>
    </nav>
    <main class="main-content">
        @RenderBody()
    </main>
    <script src="~/js/theme.js"></script>
</body>
</html>