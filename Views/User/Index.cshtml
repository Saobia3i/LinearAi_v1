@model Linear_v1.Models.ViewModels.UserLandingViewModel
@{
    ViewData["Title"] = "AI Automation Store"; Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<section class="hero-section">
    <div class="hero-content">
        <span class="hero-kicker">Premium AI Automations</span>
        <h1>Scale faster with done-for-you AI tools that sell, automate, and save time.</h1>
        <p>Launch conversion-ready workflows in minutes. No tech stress. Just results.</p>
        <div class="hero-actions">
            <a asp-action="Products" class="btn-hero-primary">Explore Products</a>
            <a asp-action="Cart" class="btn-hero-secondary">View Cart</a>
        </div>
    </div>
    <div class="hero-metrics">
        <div class="metric-card">
            <span class="metric-value">@Model.FeaturedProducts.Count+</span>
            <span class="metric-label">AI products ready</span>
        </div>
        <div class="metric-card">
            <span class="metric-value">
                @(Model.MaxVoucherDiscountPercent.HasValue ? $"{Model.MaxVoucherDiscountPercent.Value:N0}%" : "24/7")
            </span>
            <span class="metric-label">
                @(Model.MaxVoucherDiscountPercent.HasValue ? "Live voucher savings" : "Automation support")
            </span>
        </div>
        <div class="metric-card">
            <span class="metric-value">ROI</span>
            <span class="metric-label">Built for growth</span>
        </div>
    </div>
</section>

<section class="landing-section">
    <div class="section-head">
        <h2>Latest Products</h2>
        <a asp-action="Products" class="section-link">See all →</a>
    </div>

    <div class="latest-row">
        @foreach (var p in Model.LatestProducts)
        {
            var maxSubDiscount = p.Subscriptions.Any() ? p.Subscriptions.Max(s => s.DiscountPercent) : 0;
            <article class="latest-card">
                <div class="latest-badges">
                    @if (maxSubDiscount > 0)
                    {
                        <span class="discount-pill">@maxSubDiscount% OFF</span>
                    }
                    @if (Model.MaxVoucherDiscountPercent.HasValue)
                    {
                        <span class="voucher-pill">Voucher @Model.MaxVoucherDiscountPercent.Value:N0% OFF</span>
                    }
                </div>

                <h3>@p.Title</h3>
                <p>@p.ShortDescription</p>
                <div class="latest-price">From ৳@p.Price.ToString("N0")</div>
            </article>
        }
    </div>
</section>

<section class="landing-section">
    <div class="section-head">
        <h2>Shop AI Products</h2>
        @if (!string.IsNullOrWhiteSpace(Model.FeaturedVoucherCode))
        {
            <span class="voucher-code">Use: @Model.FeaturedVoucherCode</span>
        }
    </div>

    <div class="products-grid">
        @foreach (var p in Model.FeaturedProducts)
        {
            var maxSubDiscount = p.Subscriptions.Any() ? p.Subscriptions.Max(s => s.DiscountPercent) : 0;
            var bestPrice = p.Subscriptions.Any() ? p.Subscriptions.Min(s => s.FinalPrice) : p.Price;

            <div class="product-card">
                <div class="card-top-badges">
                    @if (maxSubDiscount > 0)
                    {
                        <span class="discount-pill">@maxSubDiscount% OFF</span>
                    }
                    @if (Model.MaxVoucherDiscountPercent.HasValue)
                    {
                        <span class="voucher-pill">Voucher Ready</span>
                    }
                </div>

                <h3 class="product-title">@p.Title</h3>
                <p class="product-desc">@p.ShortDescription</p>
                <div class="product-price">From ৳ @bestPrice.ToString("N0")</div>

                <form asp-action="AddToCart" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@p.Id" />
                    <input type="hidden" name="durationMonths" value="@(p.Subscriptions.Any() ? p.Subscriptions.OrderBy(s => s.DurationMonths).First().DurationMonths : 1)" />
                    <button type="submit" class="btn-buy">Add to Cart 🛒</button>
                </form>

                <a asp-action="Subscribe" asp-route-id="@p.Id" class="btn-hero-secondary" style="display:inline-block;margin-top:10px;text-decoration:none;">Choose Plan</a>
            </div>
        }
    </div>
</section>
