@model Linear_v1.Models.ApplicationUser
@{
    ViewData["Title"] = "Account";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="page-header">
    <h2>👤 My Account</h2>
</div>

<div class="card" style="max-width:700px;">
    <div class="summary-row"><span>Full Name</span><strong>@Model.FullName</strong></div>
    <div class="summary-row"><span>Email</span><strong>@Model.Email</strong></div>
    <div class="summary-row"><span>Email Confirmed</span><strong>@(Model.EmailConfirmed ? "Yes" : "No")</strong></div>
    <div class="summary-row"><span>Status</span><strong>@(Model.IsActive ? "Active" : "Inactive")</strong></div>
    <div class="summary-row"><span>Joined</span><strong>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</strong></div>

    <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:20px;">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-sm btn-danger">Logout</button>
    </form>
</div>
